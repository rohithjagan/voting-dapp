# Copy this file to .env and fill in your private key
# NEVER commit your real .env file!

# Private key of the deployer wallet (without 0x prefix)
PRIVATE_KEY=your_64_char_hex_key_here

# Alternative: use a mnemonic (if using HD wallet)
# MNEMONIC=your twelve word mnemonic phrase here

# RPC URLs (optional, defaults are in hardhat.config.ts)
# AMOY_RPC_URL=https://rpc-amoy.polygon.technology